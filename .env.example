# ZenTrack — environment template (copy to .env and fill in values)

# --- API ---
API_PORT=8000
CORS_ORIGINS=*
JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=zentrack
# Host port when using Docker Compose (avoids conflict with local Postgres on 5432)
POSTGRES_PORT=5433

# Option A: URL form (encode @ in passwords as %40)
# Local Postgres on port 5432:
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/zentrack
# Docker Postgres on port 5433:
# DATABASE_URL=postgresql://postgres:your_password_here@localhost:5433/zentrack

# Option B: Component form (used automatically in Docker via docker-compose.yml)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_NAME=zentrack

# --- Mobile (Expo) ---
# iOS simulator / web:
EXPO_PUBLIC_API_URL=http://localhost:8000
# Android emulator (use host machine IP, not localhost):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
